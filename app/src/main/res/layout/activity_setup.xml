<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvSetupTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvDestinationLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_destination"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvSetupTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDestination"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/hint_destination"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvDestinationLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDestination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPostalAddress"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvThresholdLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_threshold"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tilDestination"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilThreshold"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/hint_threshold"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvThresholdLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvDurationLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_duration"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tilThreshold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDuration"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/hint_duration"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvDurationLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:imeOptions="actionDone" />

        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnStartTracking"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/btn_start_tracking"
            android:layout_marginTop="40dp"
            android:backgroundTint="@color/primary"
            android:textSize="16sp"
            android:padding="14dp"
            app:layout_constraintTop_toBottomOf="@id/tilDuration"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnChangeApiKey"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_change_api_key"
            android:textColor="@color/primary"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnStartTracking"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
