<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvSetupTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginTop="36dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSetupSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/setup_subtitle"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvSetupTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Current Location Row -->
        <LinearLayout
            android:id="@+id/llCurrentLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:background="#1A1976D2"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:paddingStart="14dp"
            android:paddingEnd="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvSetupSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_my_location"
                android:tint="@color/primary"
                android:contentDescription="Current location" />

            <TextView
                android:id="@+id/tvCurrentLocationLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="From: "
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/tvCurrentLocation"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/current_location_detecting"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:singleLine="true"
                android:ellipsize="end" />

            <ImageButton
                android:id="@+id/btnRefreshLocation"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_refresh"
                android:tint="@color/primary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Refresh location"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Destination Label -->
        <TextView
            android:id="@+id/tvDestinationLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_destination"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/llCurrentLocation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Destination Input (larger, prominent) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDestination"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/hint_destination"
            android:layout_marginTop="8dp"
            app:boxStrokeWidth="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvDestinationLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/etDestination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPostalAddress"
                android:imeOptions="actionNext"
                android:completionThreshold="2"
                android:textSize="16sp"
                android:minHeight="56dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Threshold Label -->
        <TextView
            android:id="@+id/tvThresholdLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_threshold"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tilDestination"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Threshold Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilThreshold"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/hint_threshold"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvThresholdLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:imeOptions="actionNext"
                android:textSize="16sp"
                android:minHeight="56dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Duration Label -->
        <TextView
            android:id="@+id/tvDurationLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/label_duration"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tilThreshold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Duration Dropdown (ExposedDropdownMenu) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDuration"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/hint_duration"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvDurationLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <AutoCompleteTextView
                android:id="@+id/etDuration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"
                android:cursorVisible="false"
                android:textSize="16sp"
                android:minHeight="56dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Start Tracking Button -->
        <Button
            android:id="@+id/btnStartTracking"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/btn_start_tracking"
            android:layout_marginTop="36dp"
            android:backgroundTint="@color/primary"
            android:textSize="16sp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            app:layout_constraintTop_toBottomOf="@id/tilDuration"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- API Key Button -->
        <Button
            android:id="@+id/btnChangeApiKey"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/btn_change_api_key"
            android:textColor="@color/primary"
            android:layout_marginTop="12dp"
            app:strokeColor="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/btnStartTracking"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
